<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accessibility service: "
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_local_agent_accessibility_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_accessibility_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Open accessibility settings" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_local_agent_require_confirmation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Require confirmation before actions"
        android:textColor="@color/text_primary" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_local_agent_max_steps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Max steps">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_local_agent_max_steps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Limits how many UI actions the Local Agent can perform per request."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#2A2A2A" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="MEMORY / SCREEN CAPTURE"
        android:textColor="@color/cyan_accent"
        android:textStyle="bold"
        android:textSize="12sp"
        android:letterSpacing="0.1" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_local_agent_auto_capture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Store screen content automatically"
        android:textColor="@color/text_primary" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_local_agent_capture_interval_min"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Capture interval (minutes)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_local_agent_capture_interval_min"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_blacklist_apps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Blacklist apps for capture" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_view_screen_captures"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="View today's screen captures" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_local_agent_daily_facts_reminder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Daily notification to verify facts"
        android:textColor="@color/text_primary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_edit_daily_facts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Edit today's daily facts" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_view_confirmed_daily_facts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="View today's confirmed facts" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_view_daily_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="View today's daily summary" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_local_agent_daily_summary_refresh_hours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Auto-regenerate summary every (hours)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_local_agent_daily_summary_refresh_hours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_local_agent_auto_save_daily_facts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Auto-save daily facts from chats (draft)"
        android:textColor="@color/text_primary" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_local_agent_extract_user_fact_candidates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Extract candidate user facts from chats (review later)"
        android:textColor="@color/text_primary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_edit_persona"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Edit agent personality" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_edit_user_facts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Edit user facts" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_local_agent_view_context_debug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="View last injected context (debug)" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Screen captures are stored locally on-device (JSONL). Use blacklist for sensitive apps (banking, password managers, etc.)."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

</merge>
