<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/qc_dp_26"
    android:layout_marginRight="@dimen/qc_dp_26"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/iv_device_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="Device class"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_device_unknown" />

    <TextView
        android:id="@+id/rcv_device_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="#000"
        android:textSize="@dimen/qc_sp_18"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/iv_device_icon"
        app:layout_constraintTop_toTopOf="@+id/iv_device_icon"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/rcv_device_address"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:textColor="#333"
        android:textSize="@dimen/qc_sp_12"
        app:layout_constraintStart_toEndOf="@+id/iv_device_icon"
        app:layout_constraintTop_toBottomOf="@+id/rcv_device_name"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_detected_class"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:textColor="#555"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@+id/iv_device_icon"
        app:layout_constraintTop_toBottomOf="@+id/rcv_device_address"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_choose_device_type"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:text="Choose type"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:layout_constraintStart_toEndOf="@+id/iv_device_icon"
        app:layout_constraintTop_toBottomOf="@+id/tv_detected_class" />

    <TextView
        android:id="@+id/tv_selected_override"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:textColor="#00796B"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@+id/iv_device_icon"
        app:layout_constraintTop_toBottomOf="@+id/btn_choose_device_type"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/item_line"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="12dp"
        android:background="#22000000"
        app:layout_constraintTop_toBottomOf="@+id/tv_selected_override"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
