<?xml version="1.0" encoding="utf-8"?>
<!-- Transcripts Section Content -->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_transcript_storage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Store full transcript locally"
        android:textColor="@color/text_primary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="When OFF, the app should store only summaries + minimal metadata."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_include_full_transcription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Include full transcription in exports"
        android:textColor="@color/text_primary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="When OFF, exports should omit full transcript (best-effort)."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_auto_audio_capture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Auto-record glasses audio (15 min chunks)"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tv_auto_audio_debug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="When ON, the app will start audio recording on the glasses, stop after 15 minutes, then start a new recording repeatedly."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

</merge>
